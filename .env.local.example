# ============================================================================
# FocusFlow Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------

# MongoDB Connection String
# For local development with Docker: mongodb://localhost:27017/focusflow
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/focusflow
MONGODB_URI=mongodb://localhost:27017/focusflow

# ----------------------------------------------------------------------------
# NextAuth.js Configuration
# ----------------------------------------------------------------------------

# The URL of your app (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# Secret key for NextAuth.js session encryption
# Generate with: openssl rand -base64 32
# IMPORTANT: Use a strong, random secret in production!
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# ----------------------------------------------------------------------------
# Google OAuth (Optional)
# ----------------------------------------------------------------------------
# Skip these if you don't want Google OAuth

# Get from: https://console.cloud.google.com/
# 1. Create project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 client ID
# 4. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----------------------------------------------------------------------------
# Email Configuration (for Magic Links and Password Reset)
# ----------------------------------------------------------------------------

# Email Server (using Resend.com)
# Get API key from: https://resend.com/
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=your-api-key

# From address for emails
# Use your verified domain in production
EMAIL_FROM=noreply@focusflow.com

# ----------------------------------------------------------------------------
# Payment Gateway (Phase 6 - Razorpay)
# ----------------------------------------------------------------------------
# Uncomment and configure when implementing payments

# Get from: https://razorpay.com/
# RAZORPAY_KEY_ID=your_key_id
# RAZORPAY_KEY_SECRET=your_key_secret

# ----------------------------------------------------------------------------
# Socket.IO Server (Phase 2)
# ----------------------------------------------------------------------------
# Socket.IO server runs on port 3001 alongside Next.js (port 3000)

# Socket.IO server port
SOCKET_PORT=3001

# Public app URL (for CORS configuration)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Socket.IO server URL (for client connection)
# Local: http://localhost:3001
# Production: https://your-domain.com (use same domain as Next.js with path proxy)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# WebRTC TURN Server (Phase 3)
# ----------------------------------------------------------------------------
# Uncomment and configure when implementing video rooms
# TURN server is required for NAT traversal

# Self-hosted TURN server (coturn)
# TURN_SERVER_URL=turn:your-turn-server:3478
# TURN_USERNAME=your_username
# TURN_CREDENTIAL=your_credential

# ----------------------------------------------------------------------------
# Mediasoup SFU Configuration (Phase 4)
# ----------------------------------------------------------------------------
# Mediasoup WebRTC SFU server settings for video/audio streaming

# Mediasoup worker log level (debug, warn, error, none)
# Recommended: warn for production, debug for development
MEDIASOUP_LOG_LEVEL=warn

# RTC port range for WebRTC media streams
# Mediasoup will use ports in this range for UDP/TCP media transport
# Ensure firewall allows this range
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999

# Public IP address for ICE candidates
# This is the public IP of your server (required for ICE candidate generation)
# Get your public IP with: curl -4 ifconfig.me
# Leave empty for local development (will use 0.0.0.0)
PUBLIC_IP=your-public-ip-here

# ----------------------------------------------------------------------------
# Bandwidth Monitoring (Phase 7 - Analytics & Operations)
# ----------------------------------------------------------------------------
# Bandwidth cost calculation and alert thresholds

# Cost per GB of TURN relayed bandwidth (default: $0.01/GB)
# Used to estimate monthly TURN costs
TURN_COST_PER_GB=0.01

# Bandwidth warning threshold (default: 80% of monthly quota)
# Triggers warning alert when relayed bytes exceed this % of quota
BANDWIDTH_WARNING_THRESHOLD=80

# Bandwidth critical threshold (default: 90% of monthly quota)
# Triggers critical alert when relayed bytes exceed this % of quota
BANDWIDTH_CRITICAL_THRESHOLD=90

# Cost alert threshold (default: $5.00)
# Triggers alert when daily estimated cost exceeds this amount
BANDWIDTH_COST_THRESHOLD=5.00

# Monthly bandwidth quota in GB (default: 1000 GB)
# Used to calculate quota percentage for alerts
BANDWIDTH_MONTHLY_QUOTA_GB=1000

# Public exposure of thresholds (read-only, for dashboard display)
NEXT_PUBLIC_BANDWIDTH_WARNING_THRESHOLD=80
NEXT_PUBLIC_BANDWIDTH_CRITICAL_THRESHOLD=90
NEXT_PUBLIC_BANDWIDTH_COST_THRESHOLD=5.00
NEXT_PUBLIC_BANDWIDTH_MONTHLY_QUOTA_GB=1000

# ----------------------------------------------------------------------------
# Structured Logging (Phase 7)
# ----------------------------------------------------------------------------
# Application logging configuration

# Log level: debug, info, warn, error (default: info)
# Debug is verbose, only use in development
LOG_LEVEL=info

# Log format: json (for production log aggregators) or pretty (for development)
# Production should use json for structured logging
LOG_FORMAT=json

# ----------------------------------------------------------------------------
# Development Notes
# ----------------------------------------------------------------------------
# - Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# - For local email testing, use Mailtrap or Resend test mode
# - Google OAuth is optional - app works with just email/password
# - MongoDB can run locally via Docker or use MongoDB Atlas
# - All variables are REQUIRED unless marked as optional or for future phase
