# ============================================================================
# FocusFlow Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control (it's already in .gitignore)
# ============================================================================

# ============================================================================
# Application Configuration
# ============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32

# ============================================================================
# Database Configuration
# ============================================================================

MONGODB_URI=mongodb://localhost:27017/focusflow

# ============================================================================
# Socket.IO Server Configuration
# ============================================================================

# Socket.IO server URL (for client connection)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Socket.IO server port (default: 3001)
SOCKET_PORT=3001

# ============================================================================
# WebRTC / mediasoup Configuration
# ============================================================================

# Public IP of your server (required for ICE candidates)
# Leave empty for local development (will use localhost)
PUBLIC_IP=

# mediasoup logging level (debug | warn | error | none)
MEDIASOUP_LOG_LEVEL=warn

# RTC port range for WebRTC media streams
# Ensure these ports are open in your firewall
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999

# ============================================================================
# TURN Server Configuration
# ============================================================================
# TURN (Traversal Using Relays around NAT) is required for 20-40% of users
# behind restrictive firewalls, symmetric NAT, or corporate networks.
#
# MODES:
# 1. TURN enabled (recommended for production): Set TURN_SERVER_URL and TURN_SECRET
# 2. STUN-only (development only): Leave TURN_SERVER_URL empty, uses Google STUN
#
# TO ENABLE TURN:
# 1. Deploy TURN server (see .planning/phases/04-webrtc-integration/TURN-DEPLOYMENT.md)
# 2. Set TURN_SERVER_URL to your TURN server domain or IP
# 3. Set TURN_SECRET to the HMAC secret used by TURN server
# 4. Start TURN server: docker-compose up -d coturn
#
# TO USE STUN-ONLY (development):
# 1. Leave TURN_SERVER_URL empty (comment out or set to empty string)
# 2. Leave TURN_SECRET empty
# 3. Do NOT start coturn container
# 4. Application will use Google public STUN servers (free, but 20-40% failure rate)
# ============================================================================

# TURN server URL (domain or IP)
# Example: turn.focusflow.com or 123.45.67.89
# Leave empty to use STUN-only mode (NOT production-ready)
TURN_SERVER_URL=

# TURN HMAC secret (must match coturn configuration)
# Generate with: openssl rand -base64 32
# Leave empty to use STUN-only mode
TURN_SECRET=

# TURN external IP (auto-detect if set to 'auto')
# Only needed if TURN server is behind NAT
# TURN_EXTERNAL_IP=auto

# ============================================================================
# Email Configuration (Optional)
# ============================================================================

# SMTP settings for session reminders and notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@focusflow.com

# ============================================================================
# Payment Configuration (Indian Market)
# ============================================================================

# Razorpay API keys
# RAZORPAY_KEY_ID=your-key-id
# RAZORPAY_KEY_SECRET=your-key-secret

# ============================================================================
# Development / Testing
# ============================================================================

# Node environment (development | production | test)
NODE_ENV=development

# Enable debug logging (true | false)
DEBUG=false
