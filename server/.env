# Socket.IO Server Configuration
PORT=3001
SOCKET_PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/focusflow

# NextAuth (for JWT verification in Socket.IO middleware)
NEXTAUTH_SECRET=3TQHWMym5VCpZ7IrnOU6AFZOTCx3pYlXFbxD8FTdFg=

# CORS Configuration - Use network IP for same-network access
NEXT_PUBLIC_APP_URL=http://192.168.1.10:3000

# Mediasoup Configuration
MEDIASOUP_LOG_LEVEL=warn
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999
PUBLIC_IP=192.168.1.10

# TURN Server Configuration (Optional - for development, use STUN-only)
# Leave empty to use Google public STUN servers (STUN-only mode)
TURN_SERVER_URL=
TURN_SECRET=

# If you have deployed coturn, uncomment and configure:
# TURN_SERVER_URL=localhost
# TURN_SECRET=your-hmac-secret-here
